{
  "name": "template-law-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable multi-country shell for law MCP servers.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "scaffold:country": "npm run build && node dist/scripts/scaffold-country.js",
    "test": "npm run build && node --test dist/test/**/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
